generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Users {
  first_name      String
  last_name       String
  email           String    @unique
  birth_date      DateTime  @db.Date
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @db.Timestamp(6)
  position        String?   @default("user")
  profile_picture String?   @default("https://cdn-icons-png.flaticon.com/512/12225/12225935.png")
  banner          String?   @default("https://www.prosci.com/hubfs/worldwide-hero-banner-1920x700%20(1)-1.webp")
  id              String    @id @default(uuid()) @db.Uuid
  salary          BigInt?
  password        String?
  valid           Boolean   @default(false)
  address         String?
  filled          Boolean   @default(false)
  nationality     String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Interests {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title String
  user_id        String @db.Uuid
  description String?
}
